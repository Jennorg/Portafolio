---
import type { Technology } from '@portafolio/shared-types';
import { ui } from '../../../i18n/ui';

interface Props {
  lang: 'es' | 'en';
}

const { lang } = Astro.props;
const backendUrl = import.meta.env.BACKEND_URL;

let technologies: Technology[] = [];
let groupedTechnologies: Record<string, Technology[]> = {};
let error: string | null = null;

const cache = (globalThis as any)._astroCache = (globalThis as any)._astroCache || {};
const tKey = 'technologies_promise';
const cacheKey = 'technologies';

try {
  if (cache[cacheKey]) {
    technologies = cache[cacheKey];
  } else if (cache[tKey]) {
    technologies = await cache[tKey];
    cache[cacheKey] = technologies;
  } else {
    if (!backendUrl) {
      throw new Error("BACKEND_URL no está definida");
    }
    const response = await fetch(`${backendUrl}/api/technologies`);
    if (!response.ok) {
      throw new Error(`Error: ${response.status} ${response.statusText}`);
    }
    technologies = (await response.json()) as Technology[];
    cache[cacheKey] = technologies;
  }
} catch (e) {
  error = e instanceof Error ? e.message : "Error desconocido";
  console.error("Error fetching technologies:", e);
}

// Group technologies after fetching or retrieving from cache
groupedTechnologies = technologies.reduce((acc, tech) => {
  const categoryName = tech.category || 'Otras'; 
  
  if (!acc[categoryName]) {
    acc[categoryName] = [];
  }
  acc[categoryName].push(tech);
  return acc;
}, {} as Record<string, Technology[]>);

const priorityOrder = ['language', 'frontend', 'backend', 'mobile', 'database', 'devops', 'testing', 'tools'];

const sortedCategories = Object.keys(groupedTechnologies).sort((a, b) => {
  const indexA = priorityOrder.indexOf(a.toLowerCase());
  const indexB = priorityOrder.indexOf(b.toLowerCase());
  
  if (indexA !== -1 && indexB !== -1) return indexA - indexB;
  if (indexA !== -1) return -1;
  if (indexB !== -1) return 1;
  
  return a.localeCompare(b);
});

const getCategoryTranslation = (cat: string, targetLang: 'es' | 'en') => {
  const key = `cat_${cat.toLowerCase()}`;
  try {
    return ui[targetLang][key as any] || cat;
  } catch {
    return cat;
  }
};
---

<section id="stack" class="max-w-6xl mx-auto min-h-screen flex flex-col justify-center py-20 px-6">
  <h2 class="text-4xl font-bold text-center mb-12 bg-clip-text text-transparent bg-gradient-to-r from-primary to-accent">
    <span class="lang-es">{ui.es.stack_title}</span>
    <span class="lang-en">{ui.en.stack_title}</span>
  </h2>
  
  {error && (
    <div class="bg-red-500/10 border border-red-500/20 text-red-400 p-4 rounded-xl my-4 text-center">
      <p>
        <span class="lang-es">{ui.es.stack_error}</span>
        <span class="lang-en">{ui.en.stack_error}</span>
      </p>
      <span class="text-xs opacity-75">{error}</span>
    </div>
  )}

  {technologies.length === 0 && !error && (
    <p class="text-center text-[var(--color-text-muted)]">
      <span class="lang-es">{ui.es.stack_empty}</span>
      <span class="lang-en">{ui.en.stack_empty}</span>
    </p>
  )}

  <div class="space-y-12">
    {sortedCategories.map((category) => (
      <div class="animate-fade-in-up">
        {/* Título de la Categoría */}
        <h3 class="text-xl font-semibold mb-6 px-4 border-l-4 border-primary/50 text-[var(--color-text-body)] capitalize">
          <span class="lang-es">{getCategoryTranslation(category, 'es')}</span>
          <span class="lang-en">{getCategoryTranslation(category, 'en')}</span>
        </h3>

        {/* Grid de tecnologías para esta categoría */}
        <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6 gap-4">
          {groupedTechnologies[category].map((technology) => (
              <div class="group relative flex flex-col items-center p-4 glass-panel rounded-2xl hover:bg-white/5 transition-all duration-300 border border-transparent hover:border-primary/20">
                
                {/* Icono */}
                <div 
                  class="w-12 h-12 flex items-center justify-center text-[var(--color-text-muted)] group-hover:text-primary group-hover:scale-110 transition-all duration-300" 
                  title={technology.name}
                >
                   <div class="w-full h-full [&>svg]:w-full [&>svg]:h-full [&>svg]:fill-current" set:html={technology.icon} />
                </div>
                
                {/* Nombre */}
                <span class="text-xs font-medium mt-3 text-[var(--color-text-muted)] group-hover:text-[var(--color-text-body)] transition-colors">
                  {technology.name}
                </span>
                
              </div>
          ))}
        </div>
      </div>
    ))}
  </div>
</section>