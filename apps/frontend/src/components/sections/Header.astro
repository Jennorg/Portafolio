---
import ThemeToggleButton from '../common/ThemeToggleButton';
import LanguageToggleButton from '../common/LanguageToggleButton';
import { ui } from '../../../i18n/ui';
---

<header
  class="sticky top-0 z-50 flex justify-between items-center border-b border-header-border px-4 md:px-8 bg-header backdrop-blur-md"
>
  <nav>
    <ul class="flex gap-10 items-center py-6 font-medium">
      <li>
        <a
          href="#hero"
          class="text-muted hover:text-brand transition-colors"
        >
          <span class="lang-es">{ui.es.home}</span>
          <span class="lang-en">{ui.en.home}</span>
        </a>
      </li>
      <li>
        <a
          href="#projects"
          class="text-muted hover:text-brand transition-colors"
        >
          <span class="lang-es">{ui.es.projects}</span>
          <span class="lang-en">{ui.en.projects}</span>
        </a>
      </li>
      <li>
        <a
          href="#stack"
          class="text-muted hover:text-brand transition-colors"
        >
          <span class="lang-es">{ui.es.stack}</span>
          <span class="lang-en">{ui.en.stack}</span>
        </a>
      </li>
    </ul>
  </nav>
  <div class="flex gap-4">
    <ThemeToggleButton client:load />
    <LanguageToggleButton client:load />
  </div>
</header>
